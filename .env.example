# ========================================
# JagX WhatsApp Bot - Configuration File
# ========================================

# Bot Settings
BOT_NAME=JagX Bot
BOT_PREFIX=.
BOT_VERSION=1.0.0
DEBUG_MODE=false

# WhatsApp Settings
AUTO_READ=true
AUTO_TYPING=true
READ_RECEIPTS=true
PRESENCE_UPDATE=true

# Connection Settings
CONNECTION_TIMEOUT=30000
MESSAGE_RETRY_COUNT=3
MAX_RECONNECT_ATTEMPTS=5

# Message Settings
MAX_MESSAGE_LENGTH=4096
MESSAGE_TIMEOUT=30000
QUOTE_CHARACTER=!
COMMAND_COOLDOWN=2000

# API Keys (Get from respective services)
WEATHER_API_KEY=your_openweathermap_api_key
YOUTUBE_API_KEY=your_youtube_api_key
CRYPTO_API_KEY=your_coingecko_api_key
NEWS_API_KEY=your_newsapi_api_key
GOOGLE_CLOUD_API_KEY=your_google_cloud_key
RAPID_API_KEY=your_rapidapi_key

# Database Configuration
DB_TYPE=mongodb
DB_URL=mongodb://localhost:27017/jagx-bot
DB_USER=dbuser
DB_PASSWORD=dbpassword
DB_NAME=jagx_whatsapp_bot

# Admin Configuration
ADMIN_NUMBERS=+1234567890,+0987654321
ADMIN_PRIVILEGES=true
APPROVE_COMMANDS=false
LOG_COMMANDS=true

# Feature Toggles
ENABLE_AUTO_REPLY=true
ENABLE_MESSAGE_SCHEDULER=true
ENABLE_BROADCAST=true
ENABLE_MEDIA_PROCESSING=true
ENABLE_DOWNLOADS=true
ENABLE_ENTERTAINMENT=true
ENABLE_UTILITIES=true

# Media Processing
MAX_IMAGE_SIZE=10485760
MAX_VIDEO_SIZE=52428800
MAX_AUDIO_SIZE=20971520
COMPRESSION_QUALITY=80

# Download Settings
DOWNLOAD_TIMEOUT=60000
CONCURRENT_DOWNLOADS=3
SAVE_DOWNLOADS=true
DOWNLOADS_PATH=./downloads

# Notification Settings
SEND_STARTUP_MESSAGE=true
SEND_ERROR_ALERTS=true
ERROR_LOG_CHANNEL=

# Security
ENCRYPT_SESSIONS=true
ENCRYPT_DATA=false
BACKUP_SESSIONS=true
BACKUP_INTERVAL=86400000

# Performance
CACHE_ENABLED=true
CACHE_TTL=3600000
MAX_CACHE_SIZE=100
MEMORY_LIMIT=512

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/bot.log
MAX_LOG_SIZE=10485760
LOG_RETENTION_DAYS=30

# Development
NODE_ENV=production
SAVE_SESSION=true
SESSION_PATH=./sessions
